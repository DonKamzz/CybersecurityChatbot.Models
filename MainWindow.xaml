<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="650" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#181825">
            <StackPanel>
                <!-- Image Area -->
                <Border Height="200" 
                        Background="#1E1E2E" 
                        Margin="20,20,20,10"
                        CornerRadius="10">
                    <Image x:Name="imgLogo" 
                           Stretch="Uniform"
                           Margin="10"/>
                </Border>

                <TextBlock Text="CYBERSECURITY"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#89B4FA"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Awareness Assistant"
                           FontSize="14"
                           Foreground="#CDD6F4"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,20"/>

                <!-- About Panel -->
                <Border Background="#1E1E2E" 
                        Margin="15" 
                        Padding="15" 
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="ℹ️ ABOUT"
                                   FontWeight="Bold"
                                   Foreground="#89B4FA"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Your personal guide to online safety"
                                   Foreground="#CDD6F4"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Topics:"
                                   Foreground="#89B4FA"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Margin="0,15,0,5"/>
                        <TextBlock Text="• Password Safety" Foreground="#CDD6F4" FontSize="11"/>
                        <TextBlock Text="• Phishing Detection" Foreground="#CDD6F4" FontSize="11"/>
                        <TextBlock Text="• Scam Recognition" Foreground="#CDD6F4" FontSize="11"/>
                        <TextBlock Text="• Privacy Protection" Foreground="#CDD6F4" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Status Panel -->
                <Border Background="#1E1E2E" 
                        Margin="15" 
                        Padding="15" 
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="🟢 STATUS"
                                   Foreground="#89B4FA"
                                   FontSize="11"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="txtStatus" 
                                   Text="Online"
                                   Foreground="#A6E3A1"
                                   FontSize="12"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Main Chat Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Header -->
            <Border Grid.Row="0" 
                    Background="#1E1E2E"
                    BorderBrush="#45475A"
                    BorderThickness="0,0,0,1"
                    Height="50">
                <TextBlock Text="💬 Chat with Cybersecurity Assistant"
                           Foreground="#CDD6F4"
                           FontSize="16"
                           VerticalAlignment="Center"
                           Margin="20,0"/>
            </Border>

            <!-- Messages List -->
            <ScrollViewer x:Name="scrollViewer" 
                          Grid.Row="1"
                          Background="#1E1E2E">
                <ListBox x:Name="lstConversation" 
                         Background="Transparent" 
                         BorderThickness="0"
                         Margin="20">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="15" 
                                    Margin="5,3"
                                    Padding="12,10"
                                    Background="{Binding MsgBackground}"
                                    HorizontalAlignment="{Binding MsgAlignment}"
                                    MaxWidth="500">
                                <StackPanel>
                                    <TextBlock Text="{Binding Message}" 
                                               TextWrapping="Wrap" 
                                               Foreground="{Binding MsgForeground}"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" 
                                               FontSize="9" 
                                               Foreground="#A6ADC8"
                                               HorizontalAlignment="Right"
                                               Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- Input Area -->
            <Border Grid.Row="2" 
                    Background="#181825"
                    BorderBrush="#45475A"
                    BorderThickness="0,1,0,0"
                    Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtUserInput"
                             Grid.Column="0"
                             Height="45"
                             FontSize="14"
                             Padding="15,0"
                             Background="#1E1E2E"
                             Foreground="#CDD6F4"
                             BorderBrush="#45475A"
                             BorderThickness="1"
                             KeyDown="txtUserInput_KeyDown"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                        <Button x:Name="btnSend"
                                Content="SEND"
                                Width="80"
                                Height="45"
                                Background="#89B4FA"
                                Foreground="#1E1E2E"
                                FontWeight="Bold"
                                Click="btnSend_Click"/>

                        <Button x:Name="btnClear"
                                Content="CLEAR"
                                Width="60"
                                Height="45"
                                Margin="5,0"
                                Background="#45475A"
                                Foreground="#CDD6F4"
                                Click="btnClear_Click"/>

                        <Button x:Name="btnHelp"
                                Content="HELP"
                                Width="60"
                                Height="45"
                                Margin="5,0"
                                Background="#45475A"
                                Foreground="#CDD6F4"
                                Click="btnHelp_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>